generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())

  userRoles UserRole[]

  @@map("user")
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique

  userRoles UserRole[]

  @@map("role")
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])

  @@map("userrole")
}
